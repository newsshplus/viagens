# ============================================
# VIAGENS SMART - Variaveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha

# --- OBRIGATORIO (para busca de voos) ---
# Cadastro gratis: https://www.travelpayouts.com/
TRAVELPAYOUTS_TOKEN=

# --- OPCIONAIS (melhoram resultados) ---
# Cadastro gratis: https://rapidapi.com (Sky Scrapper - 100 req/mes gratis)
RAPIDAPI_KEY=

# --- OPCIONAL (analise IA) ---
# Cadastro gratis: https://console.groq.com/
GROQ_API_KEY=

# --- WhatsApp (Evolution API) ---
WHATSAPP_NUMBER=
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# --- GitHub (para deploy web) ---
GITHUB_TOKEN=
GITHUB_REPO=seu-usuario/viagens-smart
GITHUB_BRANCH=main
