# Nenhuma dessas é obrigatória pro sistema funcionar - sem elas, ele usa
# só o scraping gratuito do Google Flights e não envia WhatsApp (só
# imprime o resultado no log).

# Opcional - ativa a Kiwi Tequila API como segunda fonte (mais estável,
# link de compra oficial). Cadastro grátis em https://tequila.kiwi.com/
KIWI_API_KEY=

# Evolution API (WhatsApp) - sem isso, as ofertas só aparecem no log
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
